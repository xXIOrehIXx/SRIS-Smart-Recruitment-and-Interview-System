using System.Reflection;
using DbUp;
using DbUp.Engine;

namespace GP35.SRIS.DbMigrator;

/// <summary>
/// Logic migration dùng chung: gọi từ CLI (Program.cs) và từ host lúc khởi động (MigrateOrThrow).
/// Script .sql nhúng trong assembly này (Scripts/V001__, V002__, ...) chạy theo thứ tự tên,
/// ghi lịch sử vào dbo.SchemaVersions để không chạy lại.
/// </summary>
public static class SrisMigrator
{
    private static UpgradeEngine BuildUpgrader(string connectionString, bool logToConsole)
    {
        // Tạo database nếu chưa tồn tại (giống flyway tự dựng schema rỗng).
        EnsureDatabase.For.SqlDatabase(connectionString);

        var builder = DeployChanges.To
            .SqlDatabase(connectionString)
            .WithScriptsEmbeddedInAssembly(typeof(SrisMigrator).Assembly)
            .WithTransactionPerScript();

        if (logToConsole) builder = builder.LogToConsole();
        return builder.Build();
    }

    /// <summary>
    /// Chạy các migration CHƯA chạy. Dùng cho host lúc khởi động — không có script mới thì bỏ qua.
    /// Ném exception nếu migrate lỗi (để app dừng ngay thay vì chạy với DB sai).
    /// </summary>
    public static void MigrateOrThrow(string connectionString)
    {
        var result = BuildUpgrader(connectionString, logToConsole: true).PerformUpgrade();
        if (!result.Successful)
            throw new Exception("DB migration thất bại: " + result.Error?.Message, result.Error);
    }

    /// <summary>Cho CLI: migrate (mặc định) / list / mark. Trả exit code.</summary>
    public static int RunCli(string connectionString, string? command)
    {
        var upgrader = BuildUpgrader(connectionString, logToConsole: true);

        switch (command)
        {
            case "list":
            case "status":
                var pending = upgrader.GetScriptsToExecute();
                Console.WriteLine($"Migration đang chờ chạy ({pending.Count}):");
                foreach (var s in pending) Console.WriteLine("  - " + s.Name);
                if (pending.Count == 0) Console.WriteLine("  (không có — DB đã ở phiên bản mới nhất)");
                return 0;

            case "mark":
            case "baseline":
                return Report(upgrader.MarkAsExecuted(),
                    "Baseline xong: đã đánh dấu các migration hiện có là đã chạy.");

            default:
                return Report(upgrader.PerformUpgrade(), "Migrate thành công.");
        }
    }

    private static int Report(DatabaseUpgradeResult result, string okMsg)
    {
        if (result.Successful)
        {
            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine(okMsg);
            Console.ResetColor();
            return 0;
        }
        Console.ForegroundColor = ConsoleColor.Red;
        Console.Error.WriteLine(result.Error);
        Console.ResetColor();
        return -1;
    }
}
